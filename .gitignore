# ──────────────────────────────────────────────────────────────
# Hawala v2 — .gitignore
# Last reviewed: 2026-05-23 (pre-Windows migration)
# ──────────────────────────────────────────────────────────────

# ── Secrets — NEVER COMMIT ─────────────────────────────────────
.github_token
*.token
*.secret
.env
.env.*
token.env
token.env.rtf
google-backup-codes-*.txt
*backup-codes*

# ── Generated outputs (regeneratable) ─────────────────────────
market_report_*.pdf
market_report_*.html
market_signal_*.json
data_*.json
Newsletter*.pdf
Newsletter*.html
data_dumps/

# ── Large historical archives (>100MB total, regeneratable) ──
Reports-Daily-Multiple/
fii_stats_*.xls
fii_stats_*.xlsx
*.xls
*.xlsx

# ── Cached data files (regeneratable via fetchers) ─────────────
fii_data.csv
__pycache__/
*.pyc
*.pyo
.ipynb_checkpoints/

# ── 1m / OI / depth / tick / footprint caches ─────────────────
v3/cache/*.pkl
*.pkl
v3/cache/*.json
v3/cache/*.csv
v3/cache/*.ndjson
v3/cache/*.parquet
trade_logs/ticks_*.csv
trade_logs/depth_*.csv
trade_logs/*.parquet

# ── Daemon state (runtime — regenerates) ──────────────────────
alerts/.*.json
news/state/*.json
news/*.pid
news/state/*.pid

# ── OS / Editor ────────────────────────────────────────────────
.DS_Store
.idea/
.vscode/
*.swp
.claude/worktrees/

# ── Live runner logs ────────────────────────────────────────────
v3/live/runner.log
v3/live/runner_banknifty.log
*.log
logs/

# ── NSE data files (raw bhavcopy, rarely useful in git) ───────
*.spn
nsccl.*
*.zip

# ── Notebooks / scratch ─────────────────────────────────────────
*.ipynb
anaconda_projects/
combineoi_*/
-f

# ── Generated HTML viewers / footprint outputs ────────────────
research/footprint_*_*.html
research/trade_explorer.html

# ── Local dev tooling + transient data artifacts ──────────────
# Ignore local .claude state but TRACK the shared subagent definitions.
.claude/*
!.claude/agents/
trade_logs/manual_trades*.csv
v3/cache/*.preBackport
v3/cache/*.afternoon
